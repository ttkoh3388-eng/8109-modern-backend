<%- contentFor('title') %>
All Custmers

<%- contentFor('body') %>
<h1>All Customers</h1>

<table class="table">
    <thead>
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Company</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <% for (let c of customers) { %>
            <tr>
                <td>
                    <%= c.Customers.first_name %>
                </td>
                <td>
                    <%= c.Customers.last_name %>
                </td>
                <td>
                    <%= c.Customers.email %>
                </td>
                <td>
                    <%= c.Companies.name %>
                </td>
                <td>
                    <a href="/customers/<%= c.Customers.customer_id %>/update" class="btn btn-primary">Update</a>
                    <a href="/customers/<%= c.Customers.customer_id %>/delete" class="btn btn-danger">Delete</a>
                </td>
            </tr>
            <% } %>
    </tbody>
</table>